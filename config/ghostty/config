shell-integration       = zsh
macos-titlebar-style    = transparent
macos-option-as-alt     = true
font-family             = Jetbrain Mono
theme                   = Monokai Classic
cursor-style            = block
cursor-style-blink      = false
mouse-hide-while-typing = true
scrollback-limit        = 1000000
copy-on-select          = clipboard
clipboard-trim-trailing-spaces = true
window-padding-x        = 6
window-padding-y        = 4

keybind                 = super+r=reload_config
confirm-close-surface   = false

# Cmd+k -> tmux prefix + T -> sesh dashboard
keybind                 = super+k=text:\x01\x54
# Cmd+j -> tmux prefix + L -> next session
keybind                 = super+j=text:\x01\x4c
# Cmd+n -> tmux prefix + n -> next window
keybind                 = super+n=text:\x01\x6e
# Cmd+p -> tmux prefix + p -> previous window
keybind                 = super+p=text:\x01\x70
# Cmd+o -> tmux prefix + w -> windows
keybind                 = super+o=text:\x01\x77
# Cmd+i -> tmux prefix + S -> aurora/frontier workflow
keybind                 = super+i=text:\x01\x53

