shell-integration       = zsh
macos-titlebar-style    = transparent
macos-option-as-alt     = true
font-family             = Jetbrain Mono
mouse-hide-while-typing = true
scrollback-limit        = 1000000

keybind                 = super+r=reload_config
confirm-close-surface   = false

# sesh dashboard
keybind                 = super+k=text:\x01\x54
# sesh next session
keybind                 = super+j=text:\x01\x4c
# sesh next window
keybind                 = super+n=text:\x01\x6e
# sesh previous window
keybind                 = super+p=text:\x01\x70
# tmux windows
keybind                 = super+o=text:\x01\x77

