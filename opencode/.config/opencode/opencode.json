{
  "model": "github-copilot/claude-opus-4-5",
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "YOUR_API_KEY"
      ],
      "enabled": true
    },
    "ios-simulator": {
      "type": "local",
      "command": ["npx", "-y", "ios-simulator-mcp"],
      "enabled": true
    }
  },
  "keybinds": {
    "input_submit": "alt+enter",
    "input_newline": "shift+return,ctrl+return,alt+return,ctrl+n"
  }
}
