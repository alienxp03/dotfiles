#!/usr/bin/env bash

echo "Updating development environment..."

# Homebrew updates
echo "Updating Homebrew..."
brew update -y
echo "Upgrading Homebrew..."
brew upgrade -y

# ai agents
pi update
opencode upgrade

echo "Updating Mise..."
mise self-update -y

# Google Cloud SDK update
echo "Updating Google Cloud SDK..."
gcloud components update --quiet
