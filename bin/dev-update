#!/usr/bin/env bash

set -euo pipefail

echo "Updating development environment..."

# Homebrew updates
echo "Updating Homebrew..."
brew update -y
echo "Upgrading Homebrew..."
brew upgrade -y

echo "Updating mise-managed tools..."
mise run update

# Google Cloud SDK update
echo "Updating Google Cloud SDK..."
if command -v gcloud >/dev/null 2>&1; then
  gcloud components update --quiet
else
  echo "Skipping Google Cloud SDK update: gcloud not found"
fi
